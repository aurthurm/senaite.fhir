<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:five="http://namespaces.zope.org/five"
    xmlns:genericsetup="http://namespaces.zope.org/genericsetup">

  <five:registerPackage package="." initialize=".initialize"/>

  <!-- Package Includes -->
  <include package=".browser"/>
  <include package=".catalog"/>
  <include package=".converter"/>
  <include package=".finder"/>
  <include package=".r5"/>
  <include package=".resource"/>

  <!-- Default profile -->
  <genericsetup:registerProfile
    name="default"
    title="SENAITE FHIR"
    directory="profiles/default"
    description="Installs SENAITE FHIR"
    pre_handler=".setuphandlers.pre_install"
    post_handler=".setuphandlers.post_install"
    provides="Products.GenericSetup.interfaces.EXTENSION" />

  <!-- Generic Setup Handler -->
  <genericsetup:importStep
    name="senaite.fhir.setup_handler"
    title="SENAITE FHIR: Setup Handler"
    description="Run various configuration actions"
    handler=".setuphandlers.setup_handler">
  </genericsetup:importStep>

  <!-- Uninstall profile -->
  <genericsetup:registerProfile
    name="uninstall"
    title="SENAITE FHIR (uninstall)"
    directory="profiles/uninstall"
    description="Uninstalls SENAITE FHIR"
    post_handler=".setuphandlers.post_uninstall"
    provides="Products.GenericSetup.interfaces.EXTENSION" />

</configure>
