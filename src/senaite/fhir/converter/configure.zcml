<configure xmlns="http://namespaces.zope.org/zope">

  <!-- Patient To FHIR -->
  <adapter for="senaite.patient.interfaces.IPatient"
           factory=".patient.PatientToResource"/>

  <!-- FHIR To Patient -->
  <adapter for="senaite.fhir.interfaces.IPatientResource"
           factory=".patient.ResourceToPatient"/>

</configure>
